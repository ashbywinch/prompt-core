# Agent Navigation Hints
# This file helps AI agents understand the codebase structure quickly

[core-concepts]
primary-goal = "Generate structured evaluation criteria via LLM conversation"
key-constraint = "Must include 'budget' criterion and have ≥2 total criteria"
architecture = "Instructor + Pydantic for structured outputs, multi-turn conversation orchestrator"

[critical-files]
models = "prompt_core/models.py - Data models & business rule validation"
conversation = "prompt_core/conversation.py - Conversation orchestration & prompts"
llm-multi = "prompt_core/llm_interaction_multi.py - LLM provider abstraction"

[key-locations]
business-rules = "models.py:33 - validate_business_rules() method"
system-prompt = "conversation.py:53 - f-string template with {max_turns}"
turn-logic = "conversation.py:82 - process_turn() main conversation logic"

[testing]
unit-tests = "tests/unit/ - Mock-based, no API keys needed"
integration-tests = "tests/integration/ - Real API calls, require keys"
test-philosophy = "Fail without API keys to expose infrastructure issues"

[prompt-design-rules]
1 = "Never mention Pydantic class names in prompts"
2 = "Focus on behavioral guidance, not schema details"
3 = "Make turn limit configurable via f-string"
4 = "Include examples of productive vs unproductive conversations"

[configuration]
provider-model = "config.json - Provider and model settings"
api-keys = "Environment variables - API keys (OPENAI_API_KEY, OPENROUTER_API_KEY, etc.)"
config-py = "prompt_core/config.py - Loads from config.json"

[common-commands]
test-all = "make test"
test-unit = "make test-unit"
test-integration = "make test-integration (requires config.json + API keys)"
check-config = "python -c \"from prompt_core.config import config; print('Provider:', config.provider, 'Model:', config.model)\""

[setup-steps]
1 = "cp config.json.example config.json"
2 = "Edit config.json provider/model"
3 = "Set API key env var matching provider"
4 = "Run tests: make test-integration"

[quick-checks]
prompt-content = "python -c \"from prompt_core.conversation import ConversationOrchestrator; o=ConversationOrchestrator(max_turns=3); print(o.messages[0]['content'][:300])\""
business-rules = "python -c \"from prompt_core.models import EvaluationCriteria, Criterion; print('Check tests/unit/test_models.py for validation examples')\""