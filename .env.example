# LLM API Keys - REQUIRED for tests and real usage
# Configure at least one provider

# OpenAI API Key (default)
# Get your API key from: https://platform.openai.com/api-keys
# Note: $5 free credits for new users, expires after 3 months
OPENAI_API_KEY=your-openai-api-key-here

# Google Gemini API Key (recommended for free tier)
# Get your API key from: https://makersuite.google.com/app/apikey
# Free tier: 60 requests/minute, no hard monthly limit
# GOOGLE_API_KEY=your-google-api-key-here

# Groq API Key (fast, free tier available)
# Get your API key from: https://console.groq.com
# Free tier available
# GROQ_API_KEY=your-groq-api-key-here

# Optional: Specify which provider to use
# If not set, defaults to "openai" if OPENAI_API_KEY is set
# LLM_PROVIDER=google  # or "openai", "groq", "anthropic", "together"

# Optional: Model specification
# OPENAI_MODEL=gpt-4o-mini  # Cheaper for testing
# OPENAI_MODEL=gpt-4o